{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "incremental": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-ai-entry-model-selection-e2e/types/**/*.ts",
    ".next-ai-entry-validation/types/**/*.ts",
    ".next-e2e-local/types/**/*.ts",
    ".next-image-assistant-e2e/types/**/*.ts",
    ".next-lead-hunter-timing/types/**/*.ts",
    ".next-lead-hunter-workflows-e2e/types/**/*.ts",
    ".next-stream-check/types/**/*.ts",
    ".next-writer-assets-probe/types/**/*.ts",
    ".next-writer-assets-verify/types/**/*.ts",
    ".next-writer-assets-verify2/types/**/*.ts",
    ".next-writer-assets-verify3/types/**/*.ts",
    ".next-writer-real-accounts/types/**/*.ts",
    ".next-writer-real-validation/types/**/*.ts",
    ".next-writer-smoke/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "submodules",
    "infra/cloudflare/opencode-runner",
    "infra/cloudflare/dashi-ppt-smoke",
    "zola-reference",
    ".next",
    "coverage"
  ]
}
