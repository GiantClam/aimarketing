{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-build/types/**/*.ts",
    ".next-image-assistant-e2e/types/**/*.ts",
    ".next-lead-hunter-workflows-e2e/types/**/*.ts",
    ".next-stream-check/types/**/*.ts",
    ".next-writer-assets-probe/types/**/*.ts",
    ".next-writer-assets-verify/types/**/*.ts",
    ".next-writer-assets-verify2/types/**/*.ts",
    ".next-writer-real-accounts/types/**/*.ts",
    ".next-writer-real-validation/types/**/*.ts",
    ".next-writer-smoke/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-writer-assets-verify3/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "submodules",
    "zola-reference",
    ".next",
    "coverage"
  ]
}
