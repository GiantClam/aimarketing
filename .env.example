# AI entry (single-provider fail-fast routing)
# AI Chat runs in fail-fast mode: selected Provider/model errors are returned
# directly and are never auto-switched to another Provider or runtime.
AI_ENTRY_MODEL=gpt-4-mini
AI_ENTRY_PROVIDER_UPGRADE_AFTER=10
AI_ENTRY_PPTOKEN_API_KEY=
AI_ENTRY_PPTOKEN_BASE_URL=https://api.pptoken.cc/v1
AI_ENTRY_PPTOKEN_MODEL=gpt-5.4
# PPToken uses a separate account for Grok models. The Grok key is required
# when selecting pptoken/grok-*; it is never inferred from the GPT key above.
AI_ENTRY_PPTOKEN_GROK_API_KEY=
AI_ENTRY_PPTOKEN_GROK_BASE_URL=https://api.pptoken.cc/v1
# Optional aliases used by the Railway runtime/provider proxy.
PPTOKEN_GROK_API_KEY=
PPTOKEN_GROK_BASE_URL=https://api.pptoken.cc/v1
# Editable PPT assistant: OpenCode + native ppt-master skill defaults to PPToken Grok-4.5.
AI_ENTRY_PPT_ASSISTANT_DEFAULT_MODEL=grok-4.5
AI_ENTRY_DEEPSEEK_API_KEY=
AI_ENTRY_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_ENTRY_DEEPSEEK_MODEL=deepseek-v4-pro
AI_ENTRY_AIBERM_API_KEY=
AI_ENTRY_AIBERM_BASE_URL=https://aiberm.com/v1
AI_ENTRY_AIBERM_MODEL=gpt-4-mini
AI_ENTRY_CRAZYROUTE_API_KEY=
AI_ENTRY_CRAZYROUTE_BASE_URL=https://crazyrouter.com/v1
AI_ENTRY_CRAZYROUTE_MODEL=gpt-4-mini
AI_ENTRY_MCP_SERVER_URLS=

# page-agent in-browser assistant LLM (DeepSeek is preferred when configured:
# it supports the forced named tool_choice page-agent needs; otherwise the
# active AI-entry provider above is used). Set DEEPSEEK_API_KEY to switch
# page-agent to DeepSeek. Used only by /api/ai/agent-proxy.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# Thinking mode: "disabled" (default, faster) or "enabled" (model reasons first).
DEEPSEEK_THINKING=disabled

