# Database
DATABASE_URL=postgres://user:password@host:5432/aimarketing?sslmode=require
POSTGRES_URL=postgres://user:password@host:5432/aimarketing?sslmode=require

# App backends
AGENT_URL=https://agent.example.com
NEXT_PUBLIC_AGENT_URL=https://agent.example.com
WEBGEN_URL=https://webgen.example.com

# Dify
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=

# Cloudflare R2
AWS_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Feature flags
ALLOW_DEMO_LOGIN=false
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=false
NEXT_PUBLIC_ENABLE_WEBSITE_GENERATION=false
NEXT_PUBLIC_ENABLE_VIDEO_GENERATION=false
