# AI_MARKETING database and Supabase
AI_MARKETING_DB_POSTGRES_URL=postgres://user:password@host:6543/aimarketing?sslmode=require
AI_MARKETING_DB_POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/aimarketing?sslmode=require
AI_MARKETING_DB_POSTGRES_PRISMA_URL=postgres://user:password@host:6543/aimarketing?sslmode=require&pgbouncer=true
AI_MARKETING_DB_POSTGRES_HOST=host
AI_MARKETING_DB_POSTGRES_USER=postgres
AI_MARKETING_DB_POSTGRES_PASSWORD=
AI_MARKETING_DB_POSTGRES_DATABASE=postgres
AI_MARKETING_DB_SUPABASE_URL=https://your-project.supabase.co
AI_MARKETING_DB_SUPABASE_ANON_KEY=
AI_MARKETING_DB_SUPABASE_SERVICE_ROLE_KEY=
AI_MARKETING_DB_SUPABASE_JWT_SECRET=

# App backends
AGENT_URL=https://agent.example.com
NEXT_PUBLIC_AGENT_URL=https://agent.example.com
WEBGEN_URL=https://webgen.example.com
AIBERM_BASE_URL=https://aiberm.com/v1
AIBERM_API_KEY=
WRITER_AIBERM_API_KEY=
WRITER_TEXT_MODEL=google/gemini-2.5-flash
WRITER_AIBERM_IMAGE_MODEL=gemini-3.1-flash-image-preview
WRITER_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
WRITER_IMAGE_MODEL=gemini-3.1-flash-image-preview
GOOGLE_AI_API_KEY=
IMAGE_ASSISTANT_GOOGLE_MODEL=gemini-2.5-flash-image
IMAGE_ASSISTANT_GOOGLE_FALLBACK_MODELS=
IMAGE_ASSISTANT_AIBERM_MODEL=gemini-3.1-flash-image-preview
IMAGE_ASSISTANT_AIBERM_FALLBACK_MODELS=
WRITER_ENABLE_WEB_RESEARCH=true
WRITER_REQUIRE_WEB_RESEARCH=false
WRITER_RESEARCH_CACHE_TTL_MS=600000
WRITER_RESEARCH_BUDGET_MS=4500
WRITER_ENTERPRISE_KNOWLEDGE_BUDGET_MS=3000
WRITER_SEARCH_RESULT_LIMIT=4
WRITER_SEARCH_EXTRACT_LIMIT=1
WRITER_ENTERPRISE_KNOWLEDGE_CACHE_TTL_MS=300000

# Dify
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
ENTERPRISE_DIFY_BASE_URL=https://dify-api.o3-tools.com/v1
ENTERPRISE_DIFY_API_KEY=
DIFY_DEFAULT_BASE_URL=https://dify-api.o3-tools.com/v1
DIFY_DEFAULT_BRAND_API_KEY=
DIFY_DEFAULT_GROWTH_API_KEY=

# Cloudflare R2
AWS_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Feature flags
ALLOW_DEMO_LOGIN=false
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=false
NEXT_PUBLIC_ENABLE_WEBSITE_GENERATION=false
NEXT_PUBLIC_ENABLE_VIDEO_GENERATION=false
